{
  "name": "edify",
  "version": "0.1.6",
  "private": true,
  "description": "Edify, a local-first premium desktop video editor for Windows.",
  "author": "Edify",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsc -p electron/tsconfig.json --watch\" \"wait-on tcp:5173 dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc -b && tsc -p electron/tsconfig.json && vite build",
    "preview": "vite preview",
    "package:win": "npm run build && electron-builder --win nsis",
    "publish:github": "npm run build && electron-builder --win nsis --publish always",
    "lint:types": "tsc -b --pretty"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.edify.editor",
    "productName": "Edify",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      },
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "resources/ffmpeg.exe"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "icon": "resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Edify",
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "storydekito-bit",
        "repo": "Edify"
      }
    ]
  }
}
