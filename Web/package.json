{
  "name": "edify-web",
  "version": "0.1.0",
  "private": true,
  "description": "Edify web preview build with the same premium editor interface.",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --open /app.html",
    "build": "tsc -b && vite build && node scripts/write-inline-index.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "lint:types": "tsc -b --pretty"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "appwrite": "^24.2.0",
    "fix-webm-duration": "^1.0.6",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
